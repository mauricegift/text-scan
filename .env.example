# TextScan — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Gemini API Keys ───────
# One or more Gemini API keys, separated by commas.
# Keys are tried in order; if one hits its quota the next is used automatically.
# Get an api key at: https://aistudio.google.com/app/apikey
API_KEYS=your-gemini-key-1,your-gemini-key-2....

# ─── Allowed Origins ───────
# Extra origins allowed to call /extract, comma-separated (optional).
# localhost and my own giftedtech.co.ke subdomains are always allowed.
ALLOWED_ORIGINS=https://ocr.giftedtech.co.ke,http://localhost:7432

# ─── Server ─────────────
PORT=7432
